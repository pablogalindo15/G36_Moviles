<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/expenseItemContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_expense_item"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp">

    <TextView
        android:id="@+id/expenseIconTextView"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:gravity="center"
        android:text="🚗"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/expenseCategoryTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:text="Transport"
        android:textColor="#111827"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/expenseAmountTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="USD 15.00"
        android:textColor="#111827"
        android:textSize="15sp"
        android:textStyle="bold" />

</LinearLayout>