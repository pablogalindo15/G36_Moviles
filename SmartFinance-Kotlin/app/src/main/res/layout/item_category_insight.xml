<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/categoryIconTextView"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="🍽️"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/categoryNameTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:text="Food"
            android:textColor="#111827"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/categoryAmountTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="USD 120.00"
            android:textColor="#111827"
            android:textSize="14sp"
            android:textStyle="bold" />

    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:layout_marginStart="46dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_insight_bar_background">

        <View
            android:id="@+id/categoryBarView"
            android:layout_width="80dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_insight_bar_fill" />

    </FrameLayout>

</LinearLayout>